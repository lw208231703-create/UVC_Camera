# ==============================================================================
# Visual Studio / MSBuild
# ==============================================================================
.vs/
*.user
*.userosscache
*.sln.docstates
*.suo
*.db
*.opendb
*.VC.db

# ==============================================================================
# 编译输出和中间文件 (Build outputs and intermediates)
# ==============================================================================
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Oo]ut/
QtWidgetsApplication1/x64/
QtWidgetsApplication1/Debug/
QtWidgetsApplication1/Release/
# Qt 插件在 VS 中产生的特定缓存目录
QtWidgetsApplication1/QtWidget.*/

# ==============================================================================
# 编译生成的对象文件和调试文件
# ==============================================================================
*.iobj
*.ipdb
*.pdb
*.ipdb
*.ilk
*.idb
*.obj
*.o
*.tlog
*.exp
*.pch

# ==============================================================================
# Qt 特有的自动生成文件 (通常如果生成到源码目录下需要忽略)
# ==============================================================================
moc_*.cpp
moc_*.h
qrc_*.cpp
ui_*.h
Makefile*
*build-*
*.qm
*.prl

# ==============================================================================
# 忽略第三方库 (包含庞大的 CUDA, OpenCV, dll/lib 等)
# ==============================================================================
third_party/
*.dll
*.lib
*.exe

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
Thumbs.db
ehthumbs.db
desktop.ini
#忽略设计文档
*.md
#忽略日志文件
/log